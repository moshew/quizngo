# Kahoot Admin Environment Configuration

# Server URL - change this to your server's IP address for network access
# Examples:
# - For localhost only: http://localhost:5000
# - For network access: http://192.168.1.100:5000 (replace with your machine's IP)
# - For production: https://your-domain.com

VITE_SERVER_URL=http://192.168.31.22:5000

# To find your local IP address:
# Windows: ipconfig (look for IPv4 Address)
# Mac/Linux: ifconfig or ip addr show
