# QuizNGO Simulator Environment Configuration

# Load Balancer URL - change this to your LB server's IP address for network access
# Examples:
# - For localhost only: http://localhost:5000
# - For network access: http://192.168.1.100:5000 (replace with your LB machine's IP)
# - For production: https://your-domain.com

VITE_LB_URL=http://localhost:5000

# To find your local IP address:
# Windows: ipconfig (look for IPv4 Address)
# Mac/Linux: ifconfig or ip addr show
