# QuizNGO Game Server Configuration
#
# Copy this file to .env and customize for your environment
# Or set these as environment variables before running start_python script
#
# All URL parameters auto-detect the machine's LAN IP if left unset (recommended).

# Server port (default: 5001)
QUIZNGO_PORT=5001

# SSL mode for srv listener:
# 0 = HTTP (recommended for LAN and browser clients)
# 1 = HTTPS (requires localhost cert files)
QUIZNGO_SSL=0

# Load Balancer URL (server registers with the LB on startup)
# Leave unset to auto-detect LAN IP (e.g. http://192.168.1.100:5000)
# QUIZNGO_LB_URL=http://192.168.1.100:5000

# Public server address that clients will connect to
# Leave unset to auto-detect LAN IP (e.g. http://192.168.1.100:5001)
# QUIZNGO_ADDRESS=http://192.168.1.100:5001

# Examples:
# =========
#
# Auto-detect (default - all URLs use detected LAN IP):
#   QUIZNGO_PORT=5001
#   (all URLs auto-detected, e.g. http://192.168.1.100:5000, :5001, :3002, :8080)
#
# Multi-host deployment:
#   QUIZNGO_PORT=5001
#   QUIZNGO_LB_URL=http://lb-server.example.com:5000
#   QUIZNGO_ADDRESS=http://game-server-1.example.com:5001
