# Kahoot Game Server Configuration
#
# Copy this file to .env and customize for your environment
# Or set these as environment variables before running start_python script

# Server port (default: 5001)
KAHOOT_PORT=5001

# Load Balancer URL (set to 'none' for standalone mode)
KAHOOT_LB_URL=http://localhost:5000

# Public server address that clients will connect to
# Must be accessible from game clients, admin, and sim
KAHOOT_ADDRESS=http://192.168.31.22:5001

# Examples:
# =========
#
# Standalone mode (no load balancer):
#   KAHOOT_PORT=5001
#   KAHOOT_LB_URL=none
#
# Multi-host deployment with load balancer:
#   KAHOOT_PORT=5001
#   KAHOOT_LB_URL=http://lb-server.example.com:5000
#   KAHOOT_ADDRESS=http://game-server-1.example.com:5001
#
# Local development:
#   KAHOOT_PORT=5001
#   KAHOOT_LB_URL=http://localhost:5000
#   KAHOOT_ADDRESS=http://localhost:5001
