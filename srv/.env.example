# QuizNGO Game Server Configuration
#
# Copy this file to .env and customize for your environment
# Or set these as environment variables before running start_python script

# Server port (default: 5001)
QUIZNGO_PORT=5001

# Load Balancer URL (required - the game server registers with the LB on startup)
QUIZNGO_LB_URL=http://localhost:5000

# Public server address that clients will connect to
# Must be accessible from game clients, admin, and sim
QUIZNGO_ADDRESS=http://localhost:5001

# Examples:
# =========
#
# Multi-host deployment:
#   QUIZNGO_PORT=5001
#   QUIZNGO_LB_URL=http://lb-server.example.com:5000
#   QUIZNGO_ADDRESS=http://game-server-1.example.com:5001
#
# Local development:
#   QUIZNGO_PORT=5001
#   QUIZNGO_LB_URL=http://localhost:5000
#   QUIZNGO_ADDRESS=http://localhost:5001
