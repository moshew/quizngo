# Kahoot Project .gitignore

# Node modules (Add-in)
add-in/node_modules/
add-in/npm-debug.log*
add-in/yarn-debug.log*
add-in/yarn-error.log*

# Office Add-in certificates
add-in/certs/
add-in/assets/templates/

# Python virtual environment
srv/venv/
venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Server data and logs
srv/data/
srv/logs/
*.log

# Development files
.env
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Backup files
*.bak
*.backup
*~

# Temporary files
*.tmp
*.temp

game/node_modules/

# Local PPTX conversion utility files
utils/pptx2base64/pptxs/*
!utils/pptx2base64/pptxs/.gitkeep
utils/pptx2base64/output/*
!utils/pptx2base64/output/.gitkeep
