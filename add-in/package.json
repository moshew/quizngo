{
  "name": "kahoot-powerpoint-addon",
  "version": "1.0.0",
  "description": "Office Add-in לניהול חידון טריוויה ב-PowerPoint עם שרת מרכזי",
  "main": "taskpane.html",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "start-https": "node server.js",
    "start-http": "http-server . -p 3000 -c-1 --cors",
    "build": "echo 'No build process required for basic add-in'",
    "validate": "echo 'Validation requires office-addin-manifest package'",
    "serve": "node server.js",
    "sideload": "echo 'Starting HTTPS server for Office.com compatibility...' && start https://localhost:3000 && npm start",
    "certs:install": "npx office-addin-dev-certs install",
    "certs:verify": "npx office-addin-dev-certs verify"
  },
  "keywords": [
    "office-add-in",
    "powerpoint",
    "kahoot",
    "quiz",
    "trivia"
  ],
  "author": "Kahoot Quiz Manager",
  "license": "MIT",
  "devDependencies": {
    "http-server": "^14.1.1",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3"
  },
  "repository": {
    "type": "git",
    "url": "."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0"
  }
}
